---
import Base from '../layouts/Base.astro';
import NavBar from '../components/NavBar.astro';
import Glyph from '../components/Glyph.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Base title="Not found">
  <NavBar />
  <main id="main" class="page">
    <Glyph width={72} stroke={3} />
    <h1 class="message">Nothing flows through this address.</h1>
    <a href="/" class="quiet-link home">Back to the valve</a>
  </main>
  <SiteFooter />
</Base>

<style>
  .page {
    min-height: 52vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    padding: 96px 24px;
    text-align: center;
  }
  .message {
    font-size: var(--rv-body-size);
    font-weight: 400;
    color: var(--rv-text-dim);
  }
  .home {
    font-family: var(--rv-font-sans);
    font-size: 14px;
  }
</style>
