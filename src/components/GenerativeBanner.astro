---
// Deterministic riso banner for essays without commissioned art: a field of
// paper/slate fragments pouring from the left, converging through the valve
// point into a single amber line. Seeded by slug — same essay, same field.
interface Props {
  seed: string;
  /** viewBox aspect, width fixed at 1200 */
  height?: number;
}
const { seed, height = 400 } = Astro.props;

// mulberry32 over a string hash — stable across builds
function hash(s: string): number {
  let h = 1779033703 ^ s.length;
  for (let i = 0; i < s.length; i++) {
    h = Math.imul(h ^ s.charCodeAt(i), 3432918353);
    h = (h << 13) | (h >>> 19);
  }
  return h >>> 0;
}
function mulberry32(a: number) {
  return () => {
    a |= 0;
    a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(hash(seed));
const W = 1200;
const H = height;
const cy = H / 2;
const valveX = W * 0.62;

// fragments: dense at left, thinning toward the valve point
const fragments: string[] = [];
const N = 320;
for (let i = 0; i < N; i++) {
  const t = Math.pow(rand(), 1.6); // bias left
  const x = t * valveX * 1.04;
  const spread = (1 - x / valveX) * (H * 0.46) + 6;
  const y = cy + (rand() * 2 - 1) * spread;
  const r = rand();
  const size = r < 0.75 ? 1.2 + rand() * 2.2 : 2.5 + rand() * 4;
  // cold fragments only — the converging line is the one warm element
  const fill = rand() < 0.62 ? '#F4EFE6' : '#4A5A72';
  const opacity = (0.25 + rand() * 0.55).toFixed(2);
  if (rand() < 0.3) {
    fragments.push(
      `<rect x="${(x - size / 2).toFixed(1)}" y="${(y - size / 2).toFixed(1)}" width="${size.toFixed(1)}" height="${size.toFixed(1)}" fill="${fill}" opacity="${opacity}" transform="rotate(${Math.round(rand() * 90)} ${x.toFixed(1)} ${y.toFixed(1)})"/>`,
    );
  } else {
    fragments.push(
      `<circle cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="${(size / 2).toFixed(1)}" fill="${fill}" opacity="${opacity}"/>`,
    );
  }
}

const svgBody =
  fragments.join('') +
  `<path d="M${valveX} ${cy} H${W - 48}" stroke="#E3A244" stroke-width="3.5" stroke-linecap="round"/>`;
---

<div class="gen-banner" aria-hidden="true">
  <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid slice" set:html={svgBody} />
</div>

<style>
  .gen-banner {
    background: var(--rv-ink-deep);
    overflow: hidden;
  }
  .gen-banner svg {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
