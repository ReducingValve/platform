---
// Small lockup linking home, for inner pages.
import Glyph from './Glyph.astro';
import Wordmark from './Wordmark.astro';
---

<header>
  <a href="/" class="lockup">
    <Glyph width={40} stroke={4} />
    <Wordmark />
  </a>
</header>

<style>
  .lockup {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    width: fit-content;
  }
  .lockup:hover {
    opacity: 0.85;
  }
</style>
