---
// The valve-field artwork as a quiet page ground for inner pages —
// the original landing's background, kept legible under a solid scrim.
import { getImage } from 'astro:assets';
import valveField from '../assets/valve-field.png';

const avif = await getImage({ src: valveField, format: 'avif', widths: [1280, 1672], quality: 50 });
const webp = await getImage({ src: valveField, format: 'webp', widths: [1280, 1672], quality: 72 });
---

<div class="field-bg" aria-hidden="true">
  <picture>
    <source srcset={avif.srcSet.attribute} sizes="100vw" type="image/avif" />
    <img
      src={webp.src}
      srcset={webp.srcSet.attribute}
      sizes="100vw"
      alt=""
      loading="eager"
      decoding="async"
    />
  </picture>
  <div class="scrim"></div>
</div>

<style>
  .field-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }
  .field-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .scrim {
    position: absolute;
    inset: 0;
    background: rgba(16, 29, 46, 0.6);
  }
</style>
