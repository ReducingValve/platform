---
import Glyph from './Glyph.astro';
import { SITE_DESCRIPTION, TAGLINE_STRIP, CONTACT_EMAIL, SOCIALS, LICENSE } from '../consts';

const read = [
  { label: 'Essays', href: '/' },
  { label: 'RSS', href: '/rss.xml' },
  { label: 'Atom', href: '/atom.xml' },
  { label: 'JSON Feed', href: '/feed.json' },
  { label: 'llms.txt', href: '/llms.txt' },
];

const publication = [
  { label: 'About', href: '/about' },
  { label: 'Manifesto', href: '/manifesto' },
  { label: 'Openness', href: '/openness' },
];
---

<footer class="site-footer">
  <div class="frame">
    <div class="cols">
      <div class="identity">
        <Glyph width={48} stroke={3.5} />
        <p class="bio">{SITE_DESCRIPTION}</p>
        <p class="strip">{TAGLINE_STRIP}</p>
      </div>
      <nav class="col" aria-label="Read">
        <h2 class="kicker">Read</h2>
        <ul>
          {read.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </nav>
      <nav class="col" aria-label="Publication">
        <h2 class="kicker">Publication</h2>
        <ul>
          {publication.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
          <li><a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></li>
          <li class="socials">
            {SOCIALS.map((s) => <a href={s.href} target="_blank" rel="noopener">{s.label}</a>)}
          </li>
        </ul>
      </nav>
    </div>
    <div class="baseline">
      <span class="mono">thereducingvalve.com · essays {LICENSE.label} · code MIT</span>
      <span class="mono">no tracking · no ranking · published when there’s something to add</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rv-rule);
    margin-top: var(--rv-space-2xl);
    background: var(--rv-ink-deep);
  }
  .frame {
    max-width: var(--rv-frame, 1200px);
    margin: 0 auto;
    padding: 56px 24px 36px;
  }
  .cols {
    display: grid;
    grid-template-columns: minmax(260px, 1.4fr) 1fr 1fr;
    gap: 40px;
  }
  @media (max-width: 720px) {
    .cols {
      grid-template-columns: 1fr;
    }
  }
  .identity {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .bio {
    font-size: 16px;
    line-height: 1.6;
    color: var(--rv-text-dim);
    max-width: 34ch;
    text-wrap: pretty;
  }
  .strip {
    font-family: var(--rv-font-sans);
    font-size: 11px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--rv-text-dim);
  }
  .col ul {
    list-style: none;
    margin: 18px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .col a {
    font-family: var(--rv-font-sans);
    font-size: 14px;
    color: rgba(244, 239, 230, 0.72);
  }
  .col a:hover {
    color: var(--rv-link-hover);
  }
  .socials {
    display: flex;
    gap: 18px;
    margin-top: 6px;
  }
  .baseline {
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px solid var(--rv-rule);
    display: flex;
    flex-wrap: wrap;
    gap: 10px 28px;
    justify-content: space-between;
  }
</style>
