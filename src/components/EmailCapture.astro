---
// Buttondown embed form. Double opt-in is Buttondown's default:
// submitting leads to a confirmation email before any subscription.
import { BUTTONDOWN_USERNAME } from '../consts';
---

<form
  action={`https://buttondown.com/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`}
  method="post"
  class="capture"
>
  <label class="kicker" for="bd-email">New essays by email</label>
  <div class="row">
    <input
      type="email"
      name="email"
      id="bd-email"
      required
      placeholder="you@example.com"
      autocomplete="email"
    />
    <input type="hidden" value="1" name="embed" />
    <button type="submit">Subscribe</button>
  </div>
  <p class="meta">No schedule, no noise — one email when an essay appears. Unsubscribe anytime.</p>
</form>

<style>
  .capture {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 460px;
  }
  .row {
    display: flex;
    gap: 10px;
  }
  input[type='email'] {
    flex: 1;
    min-width: 0;
    background: var(--rv-ink-deep);
    border: 1px solid var(--rv-rule);
    border-radius: var(--rv-radius);
    color: var(--rv-text);
    font-family: var(--rv-font-sans);
    font-size: 15px;
    padding: 10px 14px;
  }
  input[type='email']::placeholder {
    color: var(--rv-text-faint);
  }
  input[type='email']:focus {
    outline: none;
    border-color: var(--rv-amber);
  }
  button {
    background: transparent;
    border: 1px solid var(--rv-amber);
    border-radius: var(--rv-radius);
    color: var(--rv-link);
    font-family: var(--rv-font-sans);
    font-size: 14px;
    font-weight: 500;
    padding: 10px 18px;
    cursor: pointer;
    transition: background var(--rv-duration) var(--rv-ease), color var(--rv-duration) var(--rv-ease);
  }
  button:hover {
    background: var(--rv-amber);
    color: var(--rv-navy);
  }
</style>
